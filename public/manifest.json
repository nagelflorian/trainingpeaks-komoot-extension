{
  "manifest_version": 3,
  "name": "TrainingPeaks Komoot Plugin",
  "version": "1.0.0",
  "description": "Adds a Komoot tab to TrainingPeaks workout detail view with route suggestions and activity matching.",
  "permissions": ["storage", "cookies"],
  "host_permissions": [
    "https://app.trainingpeaks.com/*",
    "https://tpapi.trainingpeaks.com/*",
    "https://account.komoot.com/*",
    "https://www.komoot.com/*",
    "https://api.komoot.de/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts"
  },
  "content_scripts": [
    {
      "matches": ["https://app.trainingpeaks.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "TP Komoot Plugin"
  },
  "options_ui": {
    "page": "src/options/index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
