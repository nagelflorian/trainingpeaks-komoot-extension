{
  "name": "trainingpeaks-komoot-extension",
  "private": true,
  "version": "1.0.0",
  "description": "Browser extension that adds a Komoot tab to TrainingPeaks workout detail view",
  "author": "Florian Nagel",
  "repository": {
    "type": "git",
    "url": "https://github.com/nagelflorian/trainingpeaks-komoot-extension.git"
  },
  "homepage": "https://github.com/nagelflorian/trainingpeaks-komoot-extension#readme",
  "bugs": {
    "url": "https://github.com/nagelflorian/trainingpeaks-komoot-extension/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -b && vite build",
    "build:safari": "xcrun safari-web-extension-converter dist/ --app-name 'TP Komoot Plugin' --bundle-identifier 'com.florian.tp-komoot-plugin' --macos-only --project-location ./xcode-app/ --no-open",
    "sync:safari": "npm run build && cp -r dist/* 'xcode-app/TP Komoot Plugin/TP Komoot Plugin Extension/'",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.1",
    "@types/webextension-polyfill": "^0.12.5",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "vite-plugin-web-extension": "^4.5.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
